# === 301 redirects: old HTMLy blog -> new Astro blog ============================
# From: https://blog.ideav.online  (HTMLy v.2.8.6, being decommissioned)
# To:   https://blog.ideav.ru      (Astro, self-canonical)
# Issue: ideav/backlogram#373 — follow-up to #331/#332. Transfers SEO weight so the
# duplicate old blog stops competing in the index and links land on the new domain.
#
# Drop this file at the web root of blog.ideav.online. Requires Apache + mod_rewrite
# (HTMLy's default stack). Mapping verified against the live sitemap + blog-v2 content:
# all old post slugs exist 1:1 on the new blog, so /YYYY/MM/<slug> maps cleanly.
# Categories and tags are mapped only where they exist on the new blog; anything else
# falls through to the new blog home so nothing 301s into a 404.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Serve real files as-is. IMPORTANT: the new blog still hotlinks images from
  #    /wp-content/uploads/ on this host — they must NOT be redirected.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 2. Keep crawler + admin endpoints on HTMLy (lets engines process the move and you
  #    manage / switch off the old blog). Delete to redirect absolutely everything.
  RewriteRule ^(robots\.txt|sitemap\.xml)$ index.php [L,QSA]
  RewriteRule ^(admin|login|logout|add|edit|api)(/|$) index.php [L,QSA]

  # 3. Posts: /YYYY/MM/<slug> -> /posts/<slug>/  (slug preserved 1:1)
  RewriteRule ^[0-9]{4}/[0-9]{2}/([^/]+)/?$ https://blog.ideav.ru/posts/$1/ [R=301,L,QSD]
  #    HTMLy non-dated post alias.
  RewriteRule ^post/([^/]+)/?$ https://blog.ideav.ru/posts/$1/ [R=301,L,QSD]

  # 4. Tag whose slug changed (HTMLy kept the dot, the new blog uses a dash).
  RewriteRule ^tag/yandeks\.direkt/?$ https://blog.ideav.ru/tag/yandeks-direkt/ [R=301,L,QSD]

  # 5. Categories present on the new blog.
  RewriteRule ^category/(o-platforme|obuchenie|pravila-predprinimatelya-v-it|proekty|razrabotka|tehnologii)/?$ https://blog.ideav.ru/category/$1/ [R=301,L,QSD]

  # 6. Tags present on the new blog.
  RewriteRule ^tag/(ai|airtable|analitika|arhitektura|avtomatizaciya|bezopasnost|bitriks24|biznes|dorabotki|excel|finmodel|ii-agent|ii-chat|integracii|integram|investicii|katalogi|keisy|konstruktor|laifhaki|low-code|marketing|no-code|obuchenie|otchety|proizvodstvo|rabota-s-dannymi|razrabotka|self-hosted|sopostavlenie|spravochniki|sravnenie|ssylki|tehnologii|vozmozhnosti|yandeks-direkt|zaprosy)/?$ https://blog.ideav.ru/tag/$1/ [R=301,L,QSD]

  # 7. Feeds -> new RSS.
  RewriteRule ^feed(/(rss|opml))?/?$ https://blog.ideav.ru/rss.xml [R=301,L,QSD]

  # 8. Everything else (home, /archive, /author, /type, /search, uncategorized,
  #    unknown taxonomy, static pages) -> new blog home.
  RewriteRule ^ https://blog.ideav.ru/ [R=301,L,QSD]
</IfModule>
