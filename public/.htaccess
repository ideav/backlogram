# Static caching + compression for ideav.ru (Apache).
#
# This file is copied verbatim by Vite into dist/ and deployed to the web root,
# so caching ships with a normal build — no server SSH required (assumes the
# vhost allows AllowOverride FileInfo). It only sets response headers and never
# touches rewrites/routing, so it is additive and safe.
#
# NOTE: HTTP/2 cannot be enabled here — it is a server-/vhost-level directive
# (`Protocols h2 http/1.1`). See docs/server-performance.md.

# ── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/json application/xml \
    image/svg+xml application/manifest+json
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml \
    application/javascript application/json application/xml \
    image/svg+xml application/manifest+json
</IfModule>

# ── Cache-Control ───────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Content-hashed build assets (…-DOaz3xWh.js / …-LufjcnuM.css) never change
  # under a given name — cache hard for a year.
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images (incl. generated OG cards) — long cache, allow revalidation.
  <FilesMatch "\.(png|jpe?g|webp|gif|svg|ico|avif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML is the entry point and is rewritten on every deploy — always
  # revalidate so visitors pick up new builds immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Crawler/meta files — modest cache.
  <FilesMatch "(sitemap\.xml|robots\.txt|llms\.txt)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
