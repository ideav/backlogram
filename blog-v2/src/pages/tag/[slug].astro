---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TagCloud from '../../components/TagCloud.astro'
import { getAllTags, getPostsByTagSlug } from '../../lib/tags'

export async function getStaticPaths() {
  const tags = await getAllTags()
  return Promise.all(
    tags.map(async (t) => {
      const posts = await getPostsByTagSlug(t.slug)
      return {
        params: { slug: t.slug },
        props: { tag: t.tag, count: t.count, posts },
      }
    })
  )
}

const { tag, count, posts } = Astro.props

// Sort newest first, assign issue numbers from the full collection ordering
import { getCollection } from 'astro:content'
const allPosts = await getCollection('posts', ({ data }) => !data.draft)
const ascending = [...allPosts].sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
)
const issueNumberOf = new Map<string, string>()
ascending.forEach((p, i) => {
  issueNumberOf.set(p.id, String(i + 1).padStart(3, '0'))
})

const display = [...posts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

function formatDate(d: Date): string {
  return d
    .toLocaleDateString('ru-RU', { day: '2-digit', month: 'long', year: 'numeric' })
    .replace(' г.', '')
}

function readingTime(body: string): number {
  return Math.max(1, Math.round(body.length / 1100))
}
---

<BaseLayout
  title={`Тег «${tag}» — Блог Интеграм`}
  description={`Статьи блога Интеграм с тегом «${tag}»: ${count} материалов о no-code, учётных системах и практике.`}
>
  <section class="max-w-[78rem] mx-auto px-6 lg:px-12 pt-14 pb-12 border-b border-[var(--color-hairline)]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10">
      <div class="lg:col-span-2 mb-6 lg:mb-0">
        <a href="/" class="eyebrow link-swipe text-[var(--color-vermilion)]">
          ← Все выпуски
        </a>
      </div>
      <div class="lg:col-span-10">
        <div class="eyebrow text-[var(--color-vermilion)] mb-3">Тег</div>
        <h1
          class="font-[family-name:var(--font-serif)] text-[3rem] sm:text-[4.4rem] leading-[0.98] tracking-[-0.022em] text-[var(--color-ink)]"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30; font-weight: 500;"
        >
          <span class="italic">{tag}</span>
          <sup
            class="text-[var(--color-vermilion)] ml-1"
            style="font-family: var(--font-mono); font-size: 0.32em; font-style: normal; font-weight: 500; letter-spacing: 0.05em; position: relative; top: -0.55em;"
          >
            {String(count).padStart(2, '0')}
          </sup>
        </h1>
        <p class="mt-5 text-lg text-[var(--color-ink-soft)] max-w-2xl">
          {count === 1
            ? 'Один материал в этом теге.'
            : `Материалов в этом теге: ${count}.`}
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-[78rem] mx-auto px-6 lg:px-12 py-14">
    <ol class="border-t border-[var(--color-hairline-strong)]">
      {display.map((post) => (
        <li class="border-b border-[var(--color-hairline)]">
          <a
            href={`/posts/${post.id}/`}
            class="group block py-7 lg:py-9 transition-colors hover:bg-[var(--color-vermilion-soft)]"
          >
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10 px-1">
              <div class="lg:col-span-2 flex lg:flex-col items-center lg:items-start gap-3 lg:gap-2 mb-4 lg:mb-0">
                <div class="issue-number text-[var(--color-vermilion)] text-2xl lg:text-3xl font-medium tracking-tight">
                  №&nbsp;{issueNumberOf.get(post.id)}
                </div>
                <div class="eyebrow text-[var(--color-ink-faint)] lg:mt-1">
                  {formatDate(post.data.pubDate)}
                </div>
              </div>
              <div class="lg:col-span-7">
                <div class="eyebrow text-[var(--color-vermilion)] mb-2">{post.data.category}</div>
                <h3
                  class="font-[family-name:var(--font-serif)] text-2xl sm:text-[1.85rem] leading-[1.12] tracking-[-0.012em] text-[var(--color-ink)] group-hover:text-[var(--color-vermilion-deep)] transition-colors"
                  style="font-variation-settings: 'opsz' 60; font-weight: 600;"
                >
                  {post.data.title}
                </h3>
                <p class="mt-3 text-[var(--color-ink-soft)] max-w-2xl">
                  {post.data.description}
                </p>
              </div>
              <div class="hidden lg:flex lg:col-span-3 items-start justify-end">
                <div class="text-right">
                  <div class="eyebrow text-[var(--color-ink-faint)]">Автор</div>
                  <div class="mt-1 text-sm text-[var(--color-ink)]">{post.data.author}</div>
                  <div class="eyebrow text-[var(--color-ink-faint)] mt-3">
                    {readingTime(post.body ?? '')}&nbsp;мин
                  </div>
                </div>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="max-w-[78rem] mx-auto px-6 lg:px-12 pb-16">
    <TagCloud activeSlug={Astro.params.slug} variant="cloud" />
  </section>
</BaseLayout>
