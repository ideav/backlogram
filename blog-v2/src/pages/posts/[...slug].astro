---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tagSlug } from '../../lib/tags'
import { categorySlug } from '../../lib/categories'

export async function getStaticPaths() {
  const all = await getCollection('posts', ({ data }) => !data.draft)
  const ascending = [...all].sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  )
  return ascending.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      issueNumber: String(i + 1).padStart(3, '0'),
    },
  }))
}

const { post, issueNumber } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.pubDate
  .toLocaleDateString('ru-RU', { day: '2-digit', month: 'long', year: 'numeric' })
  .replace(' г.', '')

const readingTime = Math.max(1, Math.round(post.body!.length / 1100))

const initial = post.data.author.charAt(0)
---

<BaseLayout
  title={`${post.data.title} — Блог Интеграм`}
  description={post.data.description}
  image={post.data.image}
  canonical={post.data.canonical}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  author={post.data.author}
>
  <article class="max-w-[78rem] mx-auto px-6 lg:px-12 pt-14 pb-24" data-pagefind-body>

    <!-- Top metadata strip — issue number, date, category, reading time -->
    <div class="flex flex-wrap items-baseline gap-x-6 gap-y-2 pb-5 border-b border-[var(--color-hairline-strong)] mb-12">
      <div class="issue-number text-[var(--color-vermilion)] text-xl font-medium tracking-tight">
        №&nbsp;{issueNumber}
      </div>
      <div class="eyebrow text-[var(--color-ink-faint)]">{formattedDate}</div>
      <div class="eyebrow text-[var(--color-vermilion)]">
        <a href={`/category/${categorySlug(post.data.category)}/`} class="link-swipe">{post.data.category}</a>
      </div>
      <div class="eyebrow text-[var(--color-ink-faint)]">{readingTime}&nbsp;мин чтения</div>
      <div class="ml-auto">
        <a href="/" class="eyebrow link-swipe text-[var(--color-ink)]">← Архив выпусков</a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10">

      <!-- Side rail: author / colophon -->
      <aside class="lg:col-span-3 lg:order-2 lg:pl-6 mb-12 lg:mb-0">
        <div class="lg:sticky lg:top-12">
          <div class="eyebrow text-[var(--color-ink-faint)] mb-3">Автор</div>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-[var(--color-vermilion)] flex items-center justify-center text-[var(--color-paper)] font-medium" style="font-family: var(--font-serif); font-variation-settings: 'opsz' 60;">
              {initial}
            </div>
            <div>
              <div class="text-[var(--color-ink)] font-medium">{post.data.author}</div>
              <div class="eyebrow text-[var(--color-ink-faint)] mt-0.5">Редакция журнала</div>
            </div>
          </div>

          {post.data.canonical && (
            <div class="mt-8 pt-6 border-t border-[var(--color-hairline)]">
              <div class="eyebrow text-[var(--color-ink-faint)] mb-2">Первая публикация</div>
              <a href={post.data.canonical} class="text-sm link-swipe text-[var(--color-ink-soft)] break-words">
                {new URL(post.data.canonical).hostname}
              </a>
            </div>
          )}

          {(post.data.tags ?? []).length > 0 && (
            <div class="mt-8 pt-6 border-t border-[var(--color-hairline)]">
              <div class="eyebrow text-[var(--color-ink-faint)] mb-3">Теги</div>
              <ul class="flex flex-wrap gap-x-3 gap-y-1.5">
                {post.data.tags!.map((t) => (
                  <li>
                    <a
                      href={`/tag/${tagSlug(t)}/`}
                      class="link-swipe text-sm text-[var(--color-ink)] hover:text-[var(--color-vermilion)]"
                    >
                      {t}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="mt-8 pt-6 border-t border-[var(--color-hairline)]">
            <div class="eyebrow text-[var(--color-ink-faint)] mb-3">Поделиться</div>
            <ul class="space-y-1.5">
              <li>
                <a
                  href={`https://t.me/share/url?url=${encodeURIComponent('https://blog.ideav.ru/posts/' + post.id + '/')}&text=${encodeURIComponent(post.data.title)}`}
                  class="link-swipe text-[var(--color-ink)] text-sm"
                >
                  Telegram
                </a>
              </li>
              <li>
                <a
                  href={`https://vk.com/share.php?url=${encodeURIComponent('https://blog.ideav.ru/posts/' + post.id + '/')}`}
                  class="link-swipe text-[var(--color-ink)] text-sm"
                >
                  ВКонтакте
                </a>
              </li>
              <li>
                <a
                  href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent('https://blog.ideav.ru/posts/' + post.id + '/')}`}
                  class="link-swipe text-[var(--color-ink)] text-sm"
                >
                  Почтой
                </a>
              </li>
            </ul>
          </div>
        </div>
      </aside>

      <!-- Main column: title + body -->
      <div class="lg:col-span-9 lg:order-1">

        <header class="mb-10 lg:mb-14 lg:pr-6">
          <h1
            class="font-[family-name:var(--font-serif)] text-[2.4rem] sm:text-[3.2rem] lg:text-[3.8rem] leading-[1.02] tracking-[-0.024em] text-[var(--color-ink)]"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 30; font-weight: 500;"
          >
            {post.data.title}
          </h1>

          <p
            class="mt-7 max-w-2xl text-xl leading-[1.55] text-[var(--color-ink-soft)] body-serif italic"
          >
            {post.data.description}
          </p>
        </header>

        {post.data.image && (
          <figure class="mb-10 lg:mb-14 -mx-6 lg:mx-0">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full"
            />
          </figure>
        )}

        <div class="prose-article lg:pr-6">
          <Content />
        </div>

        <!-- End marker + return link -->
        <div class="mt-16 pt-8 border-t border-[var(--color-hairline-strong)]">
          <div class="text-center mb-8">
            <span class="text-[var(--color-vermilion)] text-2xl" style="font-family: var(--font-serif);">❡</span>
          </div>
          <div class="flex items-center justify-between">
            <a href="/" class="eyebrow link-swipe text-[var(--color-ink)]">
              ← Все выпуски
            </a>
            <div class="eyebrow text-[var(--color-ink-faint)]">
              Выпуск №&nbsp;{issueNumber}
            </div>
          </div>
        </div>

      </div>
    </div>
  </article>
</BaseLayout>
