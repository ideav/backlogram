---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Поиск — Блог Интеграм"
  description="Поиск по статьям блога Интеграм."
>
  <section class="max-w-[78rem] mx-auto px-6 lg:px-12 pt-14 pb-12 border-b border-[var(--color-hairline)]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10">
      <div class="lg:col-span-2 mb-6 lg:mb-0">
        <a href="/" class="eyebrow link-swipe text-[var(--color-vermilion)]">
          ← Все выпуски
        </a>
      </div>
      <div class="lg:col-span-10">
        <div class="eyebrow text-[var(--color-vermilion)] mb-3">Поиск</div>
        <h1
          class="font-[family-name:var(--font-serif)] text-[3rem] sm:text-[4.4rem] leading-[0.98] tracking-[-0.022em] text-[var(--color-ink)]"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 30; font-weight: 500;"
        >
          Найти <span class="italic">в&nbsp;архиве</span>
        </h1>
        <p class="mt-5 text-lg text-[var(--color-ink-soft)] max-w-2xl">
          Поиск по полному тексту всех выпусков. Работает на стороне браузера, без сервера.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-[78rem] mx-auto px-6 lg:px-12 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10">
      <div class="lg:col-span-2"></div>
      <div class="lg:col-span-10">
        <input
          type="search"
          id="q"
          autofocus
          placeholder="Введите слово или фразу…"
          class="w-full max-w-2xl bg-transparent border-0 border-b-2 border-[var(--color-hairline-strong)] focus:border-[var(--color-vermilion)] outline-none text-[var(--color-ink)] font-[family-name:var(--font-serif)] text-2xl sm:text-3xl lg:text-4xl py-3 placeholder:text-[var(--color-ink-faint)] transition-colors"
          style="font-variation-settings: 'opsz' 60;"
        />
        <div id="status" class="eyebrow text-[var(--color-ink-faint)] mt-3 h-4"></div>

        <ol id="results" class="mt-10 border-t border-[var(--color-hairline-strong)] hidden"></ol>

        <div id="empty" class="mt-10 hidden text-[var(--color-ink-soft)]">
          Ничего не найдено. Попробуйте другие слова.
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    const input = document.getElementById('q')
    const status = document.getElementById('status')
    const results = document.getElementById('results')
    const empty = document.getElementById('empty')

    let pagefind
    let debounce

    async function ensurePagefind() {
      if (pagefind) return pagefind
      try {
        pagefind = await import('/pagefind/pagefind.js')
        await pagefind.options({ excerptLength: 30 })
      } catch (e) {
        status.textContent = 'Индекс ещё не построен. Запустите npm run build.'
        throw e
      }
      return pagefind
    }

    function escape(s) {
      return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]))
    }

    async function runSearch(query) {
      if (!query || query.length < 2) {
        results.classList.add('hidden')
        empty.classList.add('hidden')
        status.textContent = ''
        return
      }
      status.textContent = 'Ищу…'
      const pf = await ensurePagefind()
      const search = await pf.search(query)
      const hits = await Promise.all(search.results.slice(0, 25).map((r) => r.data()))
      status.textContent = hits.length === 0
        ? ''
        : `Найдено: ${search.results.length}${search.results.length > hits.length ? '. Показано первых ' + hits.length : ''}`

      if (hits.length === 0) {
        results.classList.add('hidden')
        empty.classList.remove('hidden')
        return
      }
      empty.classList.add('hidden')
      results.classList.remove('hidden')
      results.innerHTML = hits.map((h, i) => {
        const title = escape(h.meta.title || 'Без заголовка')
        const url = h.url.replace(/\/index\.html?$/, '/')
        const excerpt = h.excerpt
        return `
          <li class="border-b border-[var(--color-hairline)]">
            <a href="${url}" class="group block py-6 transition-colors hover:bg-[var(--color-vermilion-soft)]">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10 px-1">
                <div class="lg:col-span-2 mb-2 lg:mb-0">
                  <div class="issue-number text-[var(--color-vermilion)] text-xl font-medium">
                    №&nbsp;${String(i + 1).padStart(2, '0')}
                  </div>
                </div>
                <div class="lg:col-span-10">
                  <h3 class="font-[family-name:var(--font-serif)] text-2xl tracking-[-0.012em] text-[var(--color-ink)] group-hover:text-[var(--color-vermilion-deep)] transition-colors mb-2" style="font-variation-settings: 'opsz' 60; font-weight: 600;">
                    ${title}
                  </h3>
                  <p class="text-[var(--color-ink-soft)] max-w-3xl leading-relaxed pagefind-excerpt">
                    ${excerpt}
                  </p>
                </div>
              </div>
            </a>
          </li>
        `
      }).join('')
    }

    input.addEventListener('input', (e) => {
      clearTimeout(debounce)
      debounce = setTimeout(() => runSearch(e.target.value.trim()), 180)
    })

    // Allow ?q= deep linking
    const params = new URLSearchParams(location.search)
    const initial = params.get('q')
    if (initial) {
      input.value = initial
      runSearch(initial)
    }
  </script>

  <style>
    .pagefind-excerpt mark {
      background: var(--color-vermilion-soft);
      color: var(--color-vermilion-deep);
      padding: 0 0.15em;
      border-radius: 1px;
    }
  </style>
</BaseLayout>
