---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { categorySlug, getAllCategories } from '../lib/categories'

const allPosts = await getCollection('posts', ({ data }) => !data.draft)
const categories = await getAllCategories()

const ascending = [...allPosts].sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
)
const numbered = ascending.map((post, i) => ({
  ...post,
  issueNumber: String(i + 1).padStart(3, '0'),
}))

const display = [...numbered].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

type NumberedPost = typeof numbered[number]

function formatDate(d: Date): string {
  return d
    .toLocaleDateString('ru-RU', { day: '2-digit', month: 'long', year: 'numeric' })
    .replace(' г.', '')
}

function readingTime(post: NumberedPost): number {
  return Math.max(1, Math.round((post.body ?? '').length / 1100))
}

function firstImage(post: NumberedPost): string | undefined {
  if (post.data.image) return post.data.image

  const match = (post.body ?? '').match(/!\[[^\]]*\]\((\/uploads\/[^)\s]+)\)/)
  return match?.[1]
}

function decorate(post: NumberedPost, index: number) {
  return {
    post,
    image: firstImage(post),
    visual: `product-visual-${(index % 6) + 1}`,
  }
}

const featured = display[0] ? decorate(display[0], 0) : undefined
const cards = display.slice(1, 13).map((post, index) => decorate(post, index + 1))
const archive = display.slice(13)
---

<BaseLayout
  title="Блог Интеграм — статьи о no-code, данных и автоматизации"
  description="Практические статьи Интеграма о no-code, данных, self-hosted размещении, автоматизации и учетных системах."
>
  <main class="product-blog-page">
    <section class="product-blog-hero" aria-labelledby="product-blog-title">
      <div class="product-container product-blog-hero-inner">
        <div class="product-blog-hero-copy">
          <div class="eyebrow">Практика no-code и данных</div>
          <h1 id="product-blog-title">О no-code, данных и автоматизации</h1>
          <p>
            Разборы платформ, инструкции и кейсы для команд, которые строят учетные
            системы без лишней разработки.
          </p>

          <form class="product-blog-search" action="/search/" method="get" role="search">
            <label class="sr-only" for="home-blog-search">Поиск по блогу</label>
            <input
              id="home-blog-search"
              type="search"
              name="q"
              placeholder="Поиск по статьям и сценариям"
            />
            <button type="submit">Найти</button>
          </form>
        </div>

        <div class="product-blog-hero-visual" aria-hidden="true">
          <div class="product-visual-frame"></div>
          <div class="product-visual-window">
            <div class="product-visual-toolbar">
              <span></span><span></span><span></span>
            </div>
            <div class="product-visual-body">
              <div class="product-visual-column">
                <span></span><span></span><span></span><span></span>
              </div>
              <div class="product-visual-list">
                <span></span><span></span><span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="product-blog-shell" aria-label="Материалы блога">
      <div class="product-blog-topbar">
        <nav class="product-blog-category-pills" aria-label="Рубрики блога">
          <a class="product-blog-category active" href="/">
            Все <span>{display.length}</span>
          </a>
          {categories.map((category) => (
            <a class="product-blog-category" href={`/category/${category.slug}/`}>
              {category.name} <span>{category.count}</span>
            </a>
          ))}
        </nav>
      </div>

      {featured && (
        <a class="product-blog-featured" href={`/posts/${featured.post.id}/`}>
          <div class={`product-featured-media ${featured.image ? 'has-image' : featured.visual}`}>
            {featured.image ? (
              <img src={featured.image} alt="" loading="eager" />
            ) : (
              <div class="product-media-pattern" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
            )}
          </div>
          <div class="product-featured-copy">
            <div class="product-card-meta">
              {featured.post.data.category} · {formatDate(featured.post.data.pubDate)}
            </div>
            <h2>{featured.post.data.title}</h2>
            <p>{featured.post.data.description}</p>
            <span>
              № {featured.post.issueNumber} · {readingTime(featured.post)} мин чтения
            </span>
          </div>
        </a>
      )}

      {cards.length > 0 && (
        <section class="product-blog-card-grid" aria-label="Подборка статей">
          {cards.map(({ post, image, visual }) => (
            <a class="product-blog-card" href={`/posts/${post.id}/`}>
              <div class={`product-card-media ${image ? 'has-image' : visual}`}>
                {image ? (
                  <img src={image} alt="" loading="lazy" />
                ) : (
                  <div class="product-media-pattern" aria-hidden="true">
                    <span></span><span></span><span></span>
                  </div>
                )}
              </div>
              <div class="product-card-body">
                <div class="product-card-meta">
                  <span>{post.data.category}</span>
                  <span>{formatDate(post.data.pubDate)}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="product-card-foot">
                  <span>№ {post.issueNumber}</span>
                  <span>{readingTime(post)} мин</span>
                </div>
              </div>
            </a>
          ))}
        </section>
      )}

      {archive.length > 0 && (
        <section class="product-blog-archive" aria-labelledby="product-blog-archive-title">
          <div class="product-blog-archive-head">
            <div>
              <div class="eyebrow text-[var(--color-product-blue)]">Архив</div>
              <h2 id="product-blog-archive-title">Все материалы</h2>
            </div>
            <a href="/search/">Открыть поиск</a>
          </div>

          <ol>
            {archive.map((post) => (
              <li>
                <div class="issue-number">№ {post.issueNumber}</div>
                <div>
                  <a class="product-archive-category" href={`/category/${categorySlug(post.data.category)}/`}>
                    {post.data.category}
                  </a>
                  <h3>
                    <a href={`/posts/${post.id}/`}>{post.data.title}</a>
                  </h3>
                  <p>{post.data.description}</p>
                </div>
                <div class="product-archive-meta">
                  <span>{formatDate(post.data.pubDate)}</span>
                  <span>{readingTime(post)} мин</span>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}
    </section>
  </main>
</BaseLayout>
