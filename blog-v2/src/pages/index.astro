---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllCategories } from '../lib/categories'

const allPosts = await getCollection('posts', ({ data }) => !data.draft)
const categories = await getAllCategories()

const ascending = [...allPosts].sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
)
const numbered = ascending.map((post, i) => ({
  ...post,
  issueNumber: String(i + 1).padStart(3, '0'),
}))

type NumberedPost = typeof numbered[number]

const display = [...numbered].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

function formatDate(d: Date): string {
  return d
    .toLocaleDateString('ru-RU', { day: '2-digit', month: 'long', year: 'numeric' })
    .replace(' г.', '')
}

function readingTime(post: NumberedPost): number {
  return Math.max(1, Math.round((post.body ?? '').length / 1100))
}

function firstImage(post: NumberedPost): string | undefined {
  if (post.data.image) return post.data.image

  const match = (post.body ?? '').match(/!\[[^\]]*\]\((\/uploads\/[^)\s]+)\)/)
  return match?.[1]
}

function decorate(post: NumberedPost, index: number) {
  return {
    post,
    image: firstImage(post),
    visual: `visual-${(index % 6) + 1}`,
  }
}

const featured = display[0] ? decorate(display[0], 0) : undefined
const cards = display.slice(1, 13).map((post, index) => decorate(post, index + 1))
const archive = display.slice(13)
---

<BaseLayout
  title="Блог Интеграм — статьи о no-code, данных и автоматизации"
  description="Практические статьи Интеграма о no-code, данных, self-hosted размещении, автоматизации и учетных системах."
>
  <main class="amo-blog-page">
    <section class="amo-blog-hero" aria-labelledby="amo-blog-title">
      <div class="product-container amo-hero-inner">
        <div class="amo-hero-copy">
          <a class="amo-hero-kicker" href="/">Блог</a>
          <h1 id="amo-blog-title">О no-code, данных и автоматизации</h1>
          <p>
            Разборы платформ, практические инструкции и кейсы для команд, которые хотят
            управлять процессами без лишней разработки.
          </p>
        </div>

        <div class="amo-hero-visual" aria-hidden="true">
          <div class="amo-hero-frame"></div>
          <div class="amo-hero-console">
            <span></span><span></span><span></span>
            <div></div>
            <div></div>
            <div></div>
          </div>
        </div>
      </div>
    </section>

    <section class="amo-content-shell" aria-label="Материалы блога">
      <div class="amo-category-row">
        <nav class="amo-category-pills" aria-label="Рубрики блога">
          <a class="amo-category-pill active" href="/">Все</a>
          {categories.map((category) => (
            <a class="amo-category-pill" href={`/category/${category.slug}/`}>
              {category.name}
            </a>
          ))}
        </nav>

        <form class="amo-searchbar" action="/search/" method="get" role="search">
          <label class="sr-only" for="home-blog-search">Поиск по блогу</label>
          <input
            id="home-blog-search"
            type="search"
            name="q"
            placeholder="Поиск по статьям"
          />
          <button class="amo-search-button" type="submit">Найти</button>
        </form>
      </div>

      {featured && (
        <a class="amo-featured-card" href={`/posts/${featured.post.id}/`}>
          <div class={`amo-featured-media ${featured.image ? 'has-image' : featured.visual}`}>
            {featured.image ? (
              <img src={featured.image} alt="" loading="eager" />
            ) : (
              <div class="amo-media-pattern" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
            )}
          </div>
          <div class="amo-featured-content">
            <div class="amo-card-meta">
              {featured.post.data.category} · {formatDate(featured.post.data.pubDate)}
            </div>
            <h2>{featured.post.data.title}</h2>
            <p>{featured.post.data.description}</p>
            <span>
              № {featured.post.issueNumber} · {readingTime(featured.post)} мин чтения
            </span>
          </div>
        </a>
      )}

      {cards.length > 0 && (
        <section class="amo-post-grid" aria-label="Все статьи">
          {cards.map(({ post, image, visual }) => (
            <a class="amo-post-card" href={`/posts/${post.id}/`}>
              <div class={`amo-card-media ${image ? 'has-image' : visual}`}>
                {image ? (
                  <img src={image} alt="" loading="lazy" />
                ) : (
                  <div class="amo-media-pattern" aria-hidden="true">
                    <span></span><span></span><span></span>
                  </div>
                )}
              </div>
              <div class="amo-card-body">
                <div class="amo-card-meta">
                  <span class="amo-card-category">{post.data.category}</span>
                  <span>{formatDate(post.data.pubDate)}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="amo-card-foot">
                  <span>№ {post.issueNumber}</span>
                  <span>{readingTime(post)} мин</span>
                </div>
              </div>
            </a>
          ))}
        </section>
      )}

      {archive.length > 0 && (
        <div class="amo-more-row">
          <a class="amo-more-button" href="/search/">Больше полезных материалов</a>
        </div>
      )}
    </section>
  </main>
</BaseLayout>
