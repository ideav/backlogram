---
const pathname = Astro.url.pathname
const isHome = pathname === '/' || pathname === ''
---

<header class="sticky top-0 z-50 backdrop-blur-lg bg-white/70 dark:bg-slate-950/70 border-b border-slate-200 dark:border-slate-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group" aria-label="Блог Интеграм — главная">
        <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 text-white font-bold shadow-sm group-hover:shadow-md transition-shadow">
          И
        </span>
        <span class="font-semibold text-slate-900 dark:text-white">
          Блог Интеграм
        </span>
      </a>

      <nav class="flex items-center gap-1 sm:gap-2">
        <a
          href="/"
          class={`px-3 py-2 text-sm rounded-md transition-colors ${
            isHome
              ? 'text-blue-600 dark:text-blue-400 font-medium'
              : 'text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white'
          }`}
        >
          Статьи
        </a>
        <a
          href="https://ideav.ru"
          class="px-3 py-2 text-sm rounded-md text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors"
        >
          О продукте
        </a>
        <a
          href="/rss.xml"
          class="inline-flex items-center gap-1 px-2 sm:px-3 py-2 text-sm rounded-md text-slate-600 dark:text-slate-300 hover:text-orange-600 dark:hover:text-orange-400 transition-colors"
          aria-label="RSS-лента"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
          <span class="hidden sm:inline">RSS</span>
        </a>
      </nav>
    </div>
  </div>
</header>
