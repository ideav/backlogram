---
const pathname = Astro.url.pathname

function activeFor(paths: string[]): string {
  return paths.some((path) => pathname === path || pathname.startsWith(path))
    ? 'active'
    : ''
}
---

<header class="product-site-header">
  <div class="product-container product-nav-shell">
    <a href="/" class="product-brand" aria-label="Блог Интеграм — главная">
      <span class="product-mark">I</span>
      <span>Блог Интеграм</span>
    </a>

    <nav class="product-nav-links" aria-label="Основная навигация">
      <a href="/" class={pathname === '/' || pathname === '' ? 'active' : ''}>Все статьи</a>
      <a href="/category/o-platforme/" class={activeFor(['/category/o-platforme/'])}>О платформе</a>
      <a href="/category/tehnologii/" class={activeFor(['/category/tehnologii/'])}>Технологии</a>
      <a href="/category/proekty/" class={activeFor(['/category/proekty/'])}>Кейсы</a>
      <a href="/rss.xml">RSS</a>
    </nav>

    <a class="product-button" href="https://ideav.ru">Открыть Интеграм</a>
  </div>
</header>
