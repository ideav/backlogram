---
const pathname = Astro.url.pathname
const isHome = pathname === '/' || pathname === ''

const today = new Date()
const dateStamp = today
  .toLocaleDateString('ru-RU', { year: 'numeric', month: '2-digit' })
  .replace('.', '·')
---

<header class="relative border-b border-[var(--color-hairline-strong)] bg-[var(--color-paper)]">
  <div class="max-w-[78rem] mx-auto px-6 lg:px-12">
    <div class="flex items-end justify-between pt-9 pb-4">
      <a href="/" class="group block" aria-label="Блог Интеграм — главная">
        <div class="eyebrow text-[var(--color-vermilion)] mb-1">
          Изд. с 2020 · Выпуск {dateStamp}
        </div>
        <div class="font-[family-name:var(--font-serif)] text-[2rem] sm:text-[2.6rem] leading-[0.95] tracking-[-0.02em] font-semibold text-[var(--color-ink)]" style="font-variation-settings: 'opsz' 144, 'SOFT' 30;">
          Блог <span class="italic font-normal">Интеграм</span>
        </div>
      </a>

      <nav class="hidden md:flex items-center gap-7 pb-2">
        <a
          href="/"
          class={`eyebrow link-swipe ${isHome ? 'text-[var(--color-vermilion)]' : 'text-[var(--color-ink)]'}`}
        >
          Журнал
        </a>
        <a
          href="https://ideav.ru"
          class="eyebrow link-swipe text-[var(--color-ink)]"
        >
          О продукте
        </a>
        <a
          href="/rss.xml"
          class="eyebrow link-swipe text-[var(--color-ink-soft)] flex items-center gap-1.5"
          aria-label="RSS-лента"
        >
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
          RSS
        </a>
      </nav>
    </div>

    <!-- Тагline strip -->
    <div class="flex items-center justify-between border-t border-[var(--color-hairline)] py-2.5">
      <div class="eyebrow text-[var(--color-ink-faint)]">
        Записки о&nbsp;данных, учётных системах и&nbsp;no-code
      </div>
      <div class="hidden sm:flex items-center gap-4 eyebrow text-[var(--color-ink-faint)]">
        <span>Раздел<span class="text-[var(--color-vermilion)] ml-1.5">платформа</span></span>
        <span class="text-[var(--color-hairline-strong)]">/</span>
        <span>Раздел<span class="text-[var(--color-vermilion)] ml-1.5">технологии</span></span>
        <span class="text-[var(--color-hairline-strong)]">/</span>
        <span>Раздел<span class="text-[var(--color-vermilion)] ml-1.5">обучение</span></span>
      </div>
    </div>
  </div>
</header>
