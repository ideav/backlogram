---
interface Props {
  href: string
  title: string
  description: string
  category: string
  pubDate: Date
  image?: string
  featured?: boolean
}

const { href, title, description, category, pubDate, image, featured = false } = Astro.props

const formattedDate = pubDate.toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
})
---

{featured ? (
  <a
    href={href}
    class="group block rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-blue-400 dark:hover:border-blue-600 transition-all shadow-sm hover:shadow-md bg-white dark:bg-slate-900"
  >
    {image && (
      <div class="relative w-full overflow-hidden max-h-80">
        <img
          src={image}
          alt={title}
          class="w-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="eager"
        />
      </div>
    )}
    <div class="p-6 sm:p-8">
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <span class="inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
          {category}
        </span>
        <span class="text-xs text-slate-400 dark:text-slate-500">
          {formattedDate}
        </span>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
        {title}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 leading-relaxed line-clamp-3">
        {description}
      </p>
      <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 dark:text-blue-400">
        Читать статью →
      </span>
    </div>
  </a>
) : (
  <a
    href={href}
    class="group flex flex-col h-full rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-blue-400 dark:hover:border-blue-600 transition-all shadow-sm hover:shadow-md bg-white dark:bg-slate-900"
  >
    {image && (
      <div class="overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}
    <div class="flex flex-col flex-1 p-5">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">
          {category}
        </span>
        <span class="text-xs text-slate-400 dark:text-slate-500">
          {formattedDate}
        </span>
      </div>
      <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug line-clamp-3 flex-1">
        {title}
      </h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
        {description}
      </p>
      <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-blue-600 dark:text-blue-400">
        Читать →
      </span>
    </div>
  </a>
)}
