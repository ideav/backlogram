      <ul>
        <li><a class="link-swipe" href="https://ideav.ru">ideav.ru</a></li>
        <li><a class="link-swipe" href="https://integram.io">integram.io</a></li>
        <li><a class="link-swipe" href="mailto:hello@ideav.ru">hello@ideav.ru</a></li>
      </ul>
    </section>
  </div>
</footer>
