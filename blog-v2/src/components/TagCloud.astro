---
import { getAllTags } from '../lib/tags'

interface Props {
  activeSlug?: string
  variant?: 'cloud' | 'compact'
}

const { activeSlug, variant = 'cloud' } = Astro.props

const tags = await getAllTags()
if (tags.length === 0) return null
---

{variant === 'cloud' ? (
  <div class="product-section">
    <div class="product-section-heading">
      <div>
        <div class="eyebrow text-[var(--color-product-blue)]">Темы</div>
        <div class="mt-1 text-sm text-[var(--color-ink-faint)]">
          {tags.length} тегов в архиве
        </div>
      </div>
      <div>
        <h2>Навигация по задачам и сценариям</h2>
        <div class="product-pill-row mt-5">
          {tags.map((t) => {
            const isActive = activeSlug === t.slug
            return (
              <a
                href={`/tag/${t.slug}/`}
                class={`product-pill ${isActive ? 'text-[var(--color-product-blue)] border-[var(--color-product-blue)]' : ''}`}
              >
                {t.tag}
                <span class="ml-2 text-[var(--color-ink-faint)]">{t.count}</span>
              </a>
            )
          })}
        </div>
      </div>
    </div>
  </div>
) : (
  <div class="product-pill-row">
    {tags.map((t) => {
      const isActive = activeSlug === t.slug
      return (
        <a
          href={`/tag/${t.slug}/`}
          class={`product-pill ${isActive ? 'text-[var(--color-product-blue)] border-[var(--color-product-blue)]' : ''}`}
        >
          {t.tag}
          <span class="ml-2 text-[var(--color-ink-faint)]">{t.count}</span>
        </a>
      )
    })}
  </div>
)}
